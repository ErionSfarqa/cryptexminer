# Cryptex Miner - Environment Variables
# Copy this file to .env.local and fill in values

# WalletConnect Cloud Project ID (required for QR code connections)
# Get yours free at https://cloud.walletconnect.com/
NEXT_PUBLIC_WC_PROJECT_ID=""

# No API keys needed for Binance public endpoints
# Add keys here if you extend with authenticated endpoints
# NEXT_PUBLIC_BINANCE_API_KEY=
# NEXT_PUBLIC_BINANCE_API_SECRET=

# PayPal (currently using hosted button, no server-side key needed for demo)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_MODE=sandbox

# Cookie signing secret (REQUIRED in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=""

# Base URL for metadata
NEXT_PUBLIC_BASE_URL=http://localhost:3000
